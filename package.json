{
  "name": "sitewalker",
  "version": "0.1.0",
  "description": "Zero-config site mirror: sitemap-first crawl, faithful self-contained pages (JS/SPA aware), offline link rewriting, and a site-map graph.",
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "bin": {
    "sitewalker": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "check": "biome ci . && tsc --noEmit",
    "preinstall": "npx only-allow pnpm",
    "prepare": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm biome check --staged --no-errors-on-unmatched",
    "pre-push": "pnpm typecheck"
  },
  "dependencies": {
    "cheerio": "^1.0.0",
    "single-file-cli": "^2.0.83"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.4",
    "@types/node": "^22.10.0",
    "simple-git-hooks": "2.12.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
